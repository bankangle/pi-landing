# Telegram Bot notifications (server-side only — never exposed to the browser)
# 1. Create a bot via @BotFather, copy the token here.
# 2. Get your chat id (e.g. message @userinfobot, or your group's id).
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Max messenger (VK) — fill in later when ready. Left blank = skipped.
MAX_BOT_TOKEN=
MAX_CHAT_ID=
