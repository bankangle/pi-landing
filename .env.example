# ============ Lead delivery channels (all optional; unset = skipped) ============
# The lead itself is ALWAYS saved to LEADS_FILE first — channels are best-effort
# notifications on top, retried 3x with backoff.

# --- Telegram (primary) ---
# 1. Create a bot via @BotFather, copy the token.
# 2. Get your chat id (message @userinfobot, or your group's id; add bot to group).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email copy via Yandex SMTP ---
# Yandex 360: id.yandex.ru -> Security -> App passwords -> create one for "Mail".
# (Regular account password will NOT work; it must be an app password.)
SMTP_USER=hello@pi-retail.com
SMTP_PASS=
# Optional overrides: SMTP_HOST=smtp.yandex.ru SMTP_PORT=465 LEADS_EMAIL=<recipient>

# --- Max messenger (later; blank = skipped) ---
MAX_BOT_TOKEN=
MAX_CHAT_ID=

# ============ Storage & anti-spam ============
# Leads are appended here as JSONL. In Docker, mount a volume over its dir.
LEADS_FILE=./data/leads.jsonl
# Stable HMAC secret for the form time-trap token (any long random string).
# Unset = random per boot (tokens die on restart; fine for a single instance).
FORM_SECRET=

# ============ Deployment (adapter-node) ============
# ORIGIN must be the public URL for CSRF checks, e.g. https://pi-retail.com
# Behind a reverse proxy also set: ADDRESS_HEADER=x-forwarded-for (for rate limiting)
